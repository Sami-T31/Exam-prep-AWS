# ============================================================
# ROOT ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git -- it contains secrets.
# ============================================================

# --- Database (PostgreSQL) ---
# Connection string format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
POSTGRES_USER=exam_prep_user
POSTGRES_PASSWORD=exam123
POSTGRES_DB=exam_prep_db
POSTGRES_PORT=5433
DATABASE_URL=postgresql://exam_prep_user:exam123@localhost:5433/exam_prep_db?connection_limit=10&pool_timeout=30

# --- Redis ---
# Used for caching and real-time leaderboards
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# --- JWT Authentication ---
# Secret keys used to sign authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_different_random_64_char_hex_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Backend Server ---
BACKEND_PORT=3001
NODE_ENV=development

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# In development, defaults to localhost:3000 and localhost:3002 if empty.
# In production, set to your actual domain(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# --- Next.js Web App ---
# Optional: browser calls the API at this origin. If unset/empty, the web app uses /api/v1 on the
# same host and Next.js proxies to the backend (recommended for dev, including Network URLs).
# NEXT_PUBLIC_API_URL=http://localhost:3001
# Where Next.js should forward /api/v1 (server-side only; default is fine for local Nest).
# BACKEND_INTERNAL_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_NAME=Exam Prep Ethiopia
