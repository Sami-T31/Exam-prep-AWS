# Dependencies - downloaded libraries, recreated with `npm install`
node_modules/

# Environment files - contain passwords, API keys, database URLs
# NEVER commit these to Git
.env
.env.local
.env.production

# Build output - generated from source code, not worth tracking
dist/
build/
.next/
out/

# TypeScript build cache
*.tsbuildinfo

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# IDE settings (each developer has their own)
.vscode/
.idea/
*.swp
*.swo

# Docker persistent data (database files stored locally)
docker-data/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage reports
coverage/

# Prisma generated client (regenerated on install)
backend/node_modules/.prisma/
